# --- Telegram ---
# Токен бота, полученный у @BotFather. Обязательная переменная.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# --- Ollama ---
# Базовый URL локального Ollama API (обычно http://localhost:11434).
OLLAMA_BASE_URL=http://localhost:11434
# Модель по умолчанию. Должна присутствовать в OLLAMA_AVAILABLE_MODELS.
OLLAMA_DEFAULT_MODEL=qwen3.5:0.8b
# Список доступных моделей через запятую (теги из `ollama list`).
OLLAMA_AVAILABLE_MODELS=qwen3.5:0.8b,deepseek-r1:1.5b
# Таймаут на запрос к Ollama, секунды.
OLLAMA_TIMEOUT=60

# --- Bot behavior ---
# Системный промпт по умолчанию для всех пользователей.
SYSTEM_PROMPT=Ты — полезный ассистент. Отвечай кратко и по делу.

# --- Logging ---
# Уровень логов: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# Путь к файлу логов (каталог создастся автоматически).
LOG_FILE=logs/bot.log
